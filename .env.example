cat > .env.example << 'EOF'
# ============================================
# Swag Labs Test Automation - Environment Variables
# ============================================
# Copy this file to .env and update values as needed
# NEVER commit .env to version control!

# ========== URLs ==========
BASE_URL=https://www.saucedemo.com/

# ========== Test Credentials ==========
# Standard user - works normally
user=your_standard_user_here

# Password for all test accounts
password=your_password_here

# Invalid user for negative testing
wronguser=your_wrong_user_here

EOF